<% layout("./layouts/boilerplate.ejs") -%>
<body>
  <div class="row edit-listings">
    <div class="col-7 offset-2 ">
    <form action="/listings/<%=editData._id%>?_method=PUT" method="post" enctype="multipart/form-data">
      <h2>Edit Your Listing</h2>
      <label for="title" class="form-label">Title</label>
      <input type="text" name="title" class="form-control" value="<%=editData.title%>">

      <label for="description" class="form-label">Description</label>
      <textarea name="description" class="form-control"><%=editData.description%></textarea>
      <div class="mt-1">
        <p>original image</p>
        <img src="<%=originalimageurl%>" alt="original image">
      </div>
      <label for="imageurl" class="form-label">upload new Image</label>
      <input type="file" name="listing[image]" class="form-control" >
      <div class="row edit-2-row">
        <div class="col-4">
          <label for="price" class="form-label">Price</label>
          <input type="number" name="price" value="<%=editData.price%>" class="form-control">
        </div>
        <div class="col-8">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="location" value="<%=editData.location%>" class="form-control">
        </div>
      </div>
      <label for="country" class="form-label">Country</label>
      <input type="text" name="country" value="<%=editData.country%> "class="form-control">
      <label for="catagory" class="form-label">Category</label>
   <select name="catagory" class="form-control" >
    <option value="">-- Select Category --</option>
    <option value="trending">trending</option>
    <option value="rooms">Rooms</option>
    <option value="iconic">iconic</option>
    <option value="mountains">Mountains</option>
    <option value="castles">castles</option>
    <option value="Amazing pool">Amazing pool</option>
    <option value="camping">Camping</option>
    <option value="farms">Farms</option>
    <option value="arctic">arctic</option>
    <option value="beach">Beach</option>
    <option value="desert">desert</option>
  </select>
      
      <button class="btn btn-primary edit-btn">Edit</button>
      
    </form>
   </div>
   </div> 
</body>
