<% layout("./layouts/boilerplate.ejs") -%>


<%if(!alllistings.length==0){ %>
  <h2>showing best matches for <%=alllistings[0].catagory  %> </h2>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1 mt-2">
      <% for(place of alllistings){ %>
        <a href="/listing/<%=place._id%>" class="listing-link">
      <div class="card col listing-card ">
      <img src="<%=place.image.url%>" class="card-img-top" alt="listing-image" style="height: 20rem;">
      <div class="card-img-overlay"></div>
      <div class="card-body">
      <p class="card-text"><b><%=place.title%></b></p>
      <p class="card-text">&#8377; <%= place.price.toLocaleString("en-IN") %>/night <i class="tax-info">+18% GST</i></p>
      </div>
      </div>
      </a>
     <% } %>
    </div>
<% }else{%>
   <div class="filter-listings-no-match">
    <h1> Match not found !!! </h1>
   </div>
  <% } %>