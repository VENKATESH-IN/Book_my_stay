<% layout("./layouts/boilerplate.ejs") -%>
    <h1 id="allListings">All listings</h1>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1">
      <% for(place of allListings){ %>
        <a href="/listing/<%=place._id%>" class="listing-link">
      <div class="card col listing-card ">
      <img src="<%=place.image.url%>" class="card-img-top" alt="listing-image" style="height: 20rem;">
      <div class="card-img-overlay"></div>
      <div class="card-body">
      <p class="card-text"><b><%=place.title%></b></p>
      <p class="card-text">&#8377; <%= place.price.toLocaleString("en-IN") %>/night</p>
      </div>
      </div>
      </a>
     <% } %>
    </div>
      

