<% layout("./layouts/boilerplate.ejs") -%>
<body>
    <div class="row">
        <div class="col offset-2">
    <div class="card show-card listing-card" style="width: 37rem;" ;>
        <h3><%= Listings.title %></h3>
        <img src="<%= Listings.image.url %>" class="card-img-top show-image" alt="listing_image">
        <div class="card-body">
           <p class="card-text mt-2" ><%= Listings.description %> </p>
           <p class="card-text">&#8377; <%= Listings.price.toLocaleString("en-IN") %></p>
           <p class="card-text"><%= Listings.location %></p>
           <p class="card-text"><%= Listings.country %></p>
        </div>
    </div>
    </div>
    </div>
    
    <div class="row ">
        <div class="col-1 offset-2 show-btn1">
            <form action="/listings/<%= Listings._id %>/edit" method="get" >
        <button class="btn btn-primary">EDIT</button>
    </form>
        </div>
        <div class="col show-btn2">
            <form action="/listings/<%= Listings._id %>?_method=DELETE" method="post" onsubmit="return confirm('Are you want do delete permentely')">
        <button class="btn btn-primary">delete</button>
    </form>
        </div>
    </div>
    
    <div class="row mb-2 offset-2">
        <div class="col-6 offset-2 ">
            <hr>
            <h4>leave A review</h4>
            <form action="/listings/<%= Listings._id %>/reviews" method="post" novalidate class="needs-validation">
                 <div>
                      <label for="rating" class="form-label">rating</label>
                      <input type="range" max="5" min="1" name="review[rating]" id="rating" >
                 </div>

                  <div>
                     <label for="comment" class="form-label">comments</label>
                          <textarea class="form-control" name="review[comment]" id="comment" cols="30" rows="5"
                           required></textarea>
                           <div class="invalid-feedback">please fill valid feedback</div>
                  </div>
                <button class="btn btn-outline-dark mt-1">submit</button>
            </form>
             <hr>
        </div>
        <div class="allreviews">
        <h4>All Reviews</h4>
        <div class="row col-6 review-row offset-4">
             <% for(let review of Listings.reviews) {%>
                <div class="col-md-6 mb-3">
             <div class="card">
                <div class="card-body review-c-b">
                    <h5 class="card-title">jhon</h5>
                    <p class="card-text">
                        <%=review.comment%>
                    </p>
                    <p class="card-text"><%=review.rating%> Stars</p>
                </div>
                <form action="/listings/<%=Listings._id  %>/reviews/<%= review._id%>?_method=DELETE" method="post" class="mb-2 ">
                    <button class="btn btn-sm btn-dark review-del-btn">Delete</button>
                </form>
             </div>
             </div>
            <% } %>
        </div>
        </div>
    </div>  
</body>

            
            