<% layout("./layouts/boilerplate.ejs") -%>
<body>
    <div class="row">
        <div class="col offset-2">
    <div class="card show-card listing-card" style="width: 37rem;" ;>
        <h3><%= Listings.title %></h3>
        <img src="<%= Listings.image.url %>" class="card-img-top show-image" alt="listing_image">
        <div class="card-body">
           <p class="card-text mt-1">Owoned by : <%= Listings.owner.username %></p>
           <p class="card-text mt-1" ><%= Listings.description %> </p>
           <p class="card-text mt-1">&#8377; <%= Listings.price.toLocaleString("en-IN") %></p>
           <p class="card-text mt-1"><%= Listings.location %></p>
           <p class="card-text mt-1"><%= Listings.country %></p>
        </div>
    </div>
    </div>
    </div>
     

    <% if(currUser && currUser._id.equals(Listings.owner._id)){ %>
    <div class="row ">
        <div class="col-1 offset-2 show-btn1">
            <form action="/listings/<%= Listings._id %>/edit" method="get" >
        <button class="btn btn-primary">EDIT</button>
    </form>
        </div>
        <div class="col show-btn2">
            <form action="/listings/<%= Listings._id %>?_method=DELETE" method="post" onsubmit="return confirm('Are you want do delete permentely')">
        <button class="btn btn-primary">delete</button>
    </form>
        </div>
    </div>
   <% } %>
    
    <div class="row mb-2 offset-2">
        <div class="col-6 offset-2 ">
            <hr/>
            <% if(currUser){ %>
            <h4>leave A review</h4>
            <form action="/listings/<%= Listings._id %>/reviews" method="post" novalidate class="needs-validation">
                 <div>
                      <label for="rating" class="form-label">Rating</label>
                      <fieldset class="starability-slot">
                     <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" 
                     value="1" checked aria-label="No rating." />
                     <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                     <label for="first-rate1" title="Terrible">1 star</label>
                     <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                     <label for="first-rate2" title="Not good">2 stars</label>
                     <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                     <label for="first-rate3" title="Average">3 stars</label>
                     <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                     <label for="first-rate4" title="Very good">4 stars</label>
                     <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                     <label for="first-rate5" title="Amazing">5 stars</label>
                      </fieldset>
  
                 </div>
                 

                  <div>
                     <label for="comment" class="form-label">comments</label>
                          <textarea class="form-control" name="review[comment]" id="comment" cols="30" rows="5"
                           required></textarea>
                           <div class="invalid-feedback">please fill valid feedback</div>
                  </div>
                <button class="btn btn-outline-dark mt-1">submit</button>
            </form>
             <hr>
             <% } %> 
        </div>
        <div class="allreviews">
        <h4>All Reviews</h4>
        <div class="row col-6 review-row offset-4">
             <% for(let review of Listings.reviews) {%>
                <div class="col-md-6 mb-3">
             <div class="card">
                <div class="card-body review-c-b">
                    <h5 class="card-title"><%= review.author.username  %></h5>
                    <p class="card-text"><%=review.comment%></p>
                    <p class="starability-result" data-rating="<%=review.rating%>">Rated: 3 stars</p>
                </div>
                <form action="/listings/<%=Listings._id  %>/reviews/<%= review._id%>?_method=DELETE" method="post" class="mb-2 ">
                    <button class="btn btn-sm btn-dark review-del-btn">Delete</button>
                </form>
             </div>
             </div>
            <% } %>
        </div>
        </div>
    </div>  
</body>

            
            